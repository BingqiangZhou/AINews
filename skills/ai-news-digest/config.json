{
  "schema_version": "ai-news-digest-v1",
  "description": "AI 资讯日报编排器。RSS 聚合抓取 → 规则预筛 → AI 打分 → 事实素材 → 委派 article-studio 写日报文章 → 封面/插图/播客/视频 → 草稿发布。本文件同时是跨 skill 共享配置的单一来源（brand/cover/image/tts/boker_next_episode，原 audio-to-social 枢纽已删除，资产分散到各 skill）。",
  "brand": {
    "name": "AINews",
    "storage_root": ""
  },
  "sources": {
    "sources_json": "configs/bestblogs-sources/sources.json",
    "state_json": "configs/ai-news-digest/state.json",
    "types": ["ARTICLE"],
    "categories": ["Artificial_Intelligence"],
    "hours_window": 24,
    "poll_concurrency": 20,
    "poll_timeout_seconds": 15
  },
  "scoring": {
    "prefilter_top": 80,
    "ai_scored_top": 50,
    "digest_final_top": 20,
    "penalty_keywords": ["广告", "推广", "赞助", "福利", "抽奖", "限时", "秒杀", "优惠券"],
    "max_per_source": 5,
    "review_enabled": true,
    "article_min_words": 900,
    "article_max_words": 2000
  },
  "article": {
    "article_type": "news",
    "persona": "AI小周",
    "series_prefix": "AI日报"
  },
  "media": {
    "cover_enabled": true,
    "illustrations_enabled": false,
    "tts_podcast_enabled": true,
    "video_enabled": false
  },
  "platforms": {
    "gongzhonghao": {"enabled": true, "mode": "draft_only"},
    "boker": {"enabled": true},
    "douyin": {"enabled": true},
    "boker_next_episode": 1,
    "_note_boker_next_episode": "集号单一来源（跨 skill 共享）。article-to-duo-podcast 读它定集号；本 skill 发布成功后调 scripts/bump_episode.py 递增。原位于 audio-to-social/config.json。"
  },
  "cover": {
    "_note": "封面后端配置（跨 skill 共享，cover-generator/image-generator 同步引用）。原位于 audio-to-social/config.json。",
    "provider": "gaoding",
    "model": "agnes-image-2.1-flash",
    "gaoding_model": "万相2.7",
    "jimeng_model": "图片 4.7",
    "type": "auto",
    "palette": "auto",
    "rendering": "auto",
    "text": "none",
    "mood": "auto"
  },
  "image": {
    "_note": "图片尺寸（跨 skill 共享，reconcile_media.py 读 cover_size/illustration_size）。原位于 audio-to-social/config.json。",
    "output_format": "png",
    "quality": 80,
    "cover_size": "900x383",
    "illustration_size": "1920x1080"
  },
  "tts": {
    "_note": "TTS 配置（跨 skill 共享，tts-generation/article-to-duo-podcast 同步引用）。原位于 audio-to-social/config.json。",
    "provider": "mimo",
    "voice": "苏打",
    "model": "mimo-v2.5-tts-voiceclone",
    "clone": true,
    "style": null,
    "ref_audio": null
  },
  "environment": {
    "conda_python": "python",
    "ffmpeg": "ffmpeg",
    "ffprobe": "ffprobe",
    "font": "",
    "wechat_mp_appid_env": "WECHAT_MP_APPID",
    "wechat_mp_appsecret_env": "WECHAT_MP_APPSECRET",
    "mimo_api_key_env": "MIMO_API_KEY",
    "agnes_api_key_env": "AGNES_API_KEY"
  },
  "shared_assets_locations": {
    "_note": "audio-to-social 目录已删除。跨 skill 共享资产的新位置（本 config 是 brand/cover/image/tts/boker_next_episode 的单一源）:",
    "lib_utils": "../whisper-transcribe/scripts/lib/utils.py",
    "voice_ref_wav": "../tts-generation/scripts/voice_ref.wav",
    "brand_config": "../article-studio/references/brand-config.md",
    "validate_content_quality_script": "../article-studio/scripts/validate_content_quality.py",
    "backup_file_script": "./scripts/backup_file.py",
    "bump_episode_script": "./scripts/bump_episode.py",
    "compress_images_script": "./scripts/compress_images.py",
    "reconcile_media_script": "./scripts/reconcile_media.py",
    "agent_shared_base": "./agents/_shared_base.md"
  }
}
