{
  "schema_version": "article-to-video-v1",
  "video": {
    "width": 1920,
    "height": 1080,
    "fps": 30,
    "codec": "libx264",
    "pix_fmt": "yuv420p",
    "crf": 18,
    "preset": "medium",
    "audio_bitrate": "192k"
  },
  "cover": {
    "duration_sec": 4,
    "enabled": false,
    "ken_burns": "static"
  },
  "ken_burns": {
    "min_zoom": 1.0,
    "max_zoom": 1.15,
    "pan_range": 0.08,
    "min_scene_sec": 6,
    "max_scene_sec": 60,
    "_note": "min/max_scene_sec 用于过长或过短场景的钳制；pan_range 是平移幅度占画面的比例"
  },
  "subtitles": {
    "font": "Microsoft YaHei",
    "fontsize": 42,
    "primary_color": "&H00FFFFFF",
    "outline_color": "&H00000000",
    "outline_width": 2,
    "shadow": 1,
    "margin_v": 40,
    "max_chars_per_line": 26,
    "margin_l": 320,
    "margin_r": 320,
    "border_style": 3,
    "back_color": "&H80000000",
    "_note": "primary_color 是 ASS BGR+alpha 格式；margin_v 是字幕距底部边距（像素，减小=字幕更靠下）；margin_l/margin_r 是左右边距（限制字幕在中间 2/3 宽度）；max_chars_per_line 超过才在标点处断行；border_style 1=描边 3=背景框；back_color 是背景框颜色（BorderStyle=3 时生效），&H80000000=半透明黑"
  },
  "whisper": {
    "model": "large-v3-turbo",
    "device": "cuda",
    "lang": "zh"
  },
  "environment": {
    "conda_python": "python",
    "ffmpeg": "ffmpeg",
    "ffprobe": "ffprobe"
  }
}
