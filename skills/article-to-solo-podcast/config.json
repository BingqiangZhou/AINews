{
  "schema_version": "article-to-solo-podcast-v1",
  "brand": {
    "name": "AINews",
    "host_identity": "我是AINews"
  },
  "tts": {
    "provider": "mimo",
    "voice": "苏打",
    "model": "mimo-v2.5-tts-voiceclone",
    "clone": true,
    "ref_audio": "../tts-generation/scripts/voice_ref.wav",
    "format": "mp3",
    "bitrate": "320k"
  },
  "content": {
    "min_chars": 1550,
    "max_chars": 2500,
    "max_para_chars": 80,
    "target_minutes": "8-12",
    "machine_word_blocklist_extra": [],
    "_note_machine_words": "AI-腔禁用词单一权威源 = article-studio/references/brand-config.md 的 '## 禁用 AI 腔短语'（validate_solo_script.py 运行时解析，与 validate_content_quality.py 同源）。本字段 machine_word_blocklist_extra 仅用于追加该列表之外的补充词，默认为空。"
  },
  "evaluation": {
    "max_fix_rounds": 3,
    "market_ready_bar": {
      "min_per_dimension": 4,
      "min_overall": 4.0,
      "fidelity_must_be_clean": true
    },
    "factcheck": {
      "enabled": true,
      "hard_fact_patterns": [
        "\\d+\\.\\d+(\\.\\d+)?",
        "v\\d+\\.\\d+",
        "20\\d{2}[-/年.]?\\d{1,2}",
        "第?\\d+版"
      ],
      "soft_fail_on_network": true
    }
  },
  "publishing": {
    "boker_episode_config": "../ai-news-digest/config.json",
    "bump_episode_script": "../ai-news-digest/scripts/bump_episode.py",
    "auto_publish": false
  },
  "studio": {
    "enabled": true,
    "host_listen_max_rounds": 3,
    "total_call_cap": 20,
    "fast_fallback": false,
    "_note": "Phase 2 编剧室开关；fast_fallback=true 或 enabled=false 时退回单 solo-scriptwriter"
  },
  "environment": {
    "conda_python": "python",
    "ffmpeg": "ffmpeg",
    "mimo_api_key_env": "MIMO_API_KEY"
  }
}
