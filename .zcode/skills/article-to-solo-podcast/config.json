{
  "schema_version": "article-to-solo-podcast-v1",
  "brand": {
    "name": "AINews",
    "host_identity": "我是AINews"
  },
  "tts": {
    "provider": "mimo",
    "voice": "苏打",
    "model": "mimo-v2.5-tts-voiceclone",
    "clone": true,
    "ref_audio": "../audio-to-social/scripts/voice_ref.wav",
    "format": "mp3",
    "bitrate": "320k"
  },
  "content": {
    "min_chars": 1550,
    "max_chars": 2500,
    "max_para_chars": 80,
    "target_minutes": "8-12",
    "machine_word_blocklist": [
      "首先",
      "其次",
      "再次",
      "综上所述",
      "总而言之",
      "值得一提的是",
      "不可否认",
      "毋庸置疑",
      "不难发现",
      "众所周知"
    ]
  },
  "evaluation": {
    "max_fix_rounds": 3,
    "market_ready_bar": {
      "min_per_dimension": 4,
      "min_overall": 4.0,
      "fidelity_must_be_clean": true
    },
    "factcheck": {
      "enabled": true,
      "hard_fact_patterns": [
        "\\d+\\.\\d+(\\.\\d+)?",
        "v\\d+\\.\\d+",
        "20\\d{2}[-/年.]?\\d{1,2}",
        "第?\\d+版"
      ],
      "soft_fail_on_network": true
    }
  },
  "publishing": {
    "boker_episode_config": "../audio-to-social/config.json",
    "bump_episode_script": "../audio-to-social/scripts/bump_episode.py",
    "auto_publish": false
  },
  "studio": {
    "enabled": true,
    "host_listen_max_rounds": 3,
    "total_call_cap": 20,
    "fast_fallback": false,
    "_note": "Phase 2 编剧室开关；fast_fallback=true 或 enabled=false 时退回单 solo-scriptwriter"
  },
  "environment": {
    "conda_python": "D:\\Development\\miniconda3\\python.exe",
    "ffmpeg": "ffmpeg",
    "mimo_api_key_env": "MIMO_API_KEY"
  }
}
