{
  "schema_version": "ai-news-digest-v1",
  "description": "AI 资讯日报编排器。RSS 聚合抓取 → 规则预筛 → AI 打分 → 事实素材 → 委派 article-studio 写日报文章 → 封面/插图/播客/视频 → 草稿发布。",
  "brand": {
    "name": "AINews",
    "storage_root": "E:\\Projects\\AI\\AINews"
  },
  "sources": {
    "sources_json": "configs/bestblogs-sources/sources.json",
    "state_json": "configs/ai-news-digest/state.json",
    "types": ["ARTICLE"],
    "categories": ["Artificial_Intelligence"],
    "hours_window": 24,
    "poll_concurrency": 20,
    "poll_timeout_seconds": 15
  },
  "scoring": {
    "prefilter_top": 80,
    "ai_scored_top": 50,
    "digest_final_top": 20,
    "penalty_keywords": ["广告", "推广", "赞助", "福利", "抽奖", "限时", "秒杀", "优惠券"],
    "max_per_source": 5,
    "article_min_words": 900,
    "article_max_words": 2000
  },
  "article": {
    "article_type": "news",
    "persona": "AI小周",
    "series_prefix": "AI日报"
  },
  "media": {
    "cover_enabled": true,
    "illustrations_enabled": true,
    "tts_podcast_enabled": true,
    "video_enabled": true
  },
  "platforms": {
    "gongzhonghao": {"enabled": true, "mode": "draft_only"},
    "boker": {"enabled": true},
    "douyin": {"enabled": true}
  },
  "environment": {
    "conda_python": "D:\\Development\\miniconda3\\python.exe",
    "ffmpeg": "ffmpeg",
    "font": "C:\\Windows\\Fonts\\msyh.ttc",
    "wechat_mp_appid_env": "WECHAT_MP_APPID",
    "wechat_mp_appsecret_env": "WECHAT_MP_APPSECRET",
    "mimo_api_key_env": "MIMO_API_KEY",
    "agnes_api_key_env": "AGNES_API_KEY"
  },
  "reused_from_audio_to_social": {
    "cover": "../audio-to-social/config.json#cover",
    "image": "../audio-to-social/config.json#image",
    "tts": "../audio-to-social/config.json#tts",
    "boker_next_episode": "../audio-to-social/config.json#platforms.boker_next_episode",
    "validate_quality_script": "../audio-to-social/scripts/validate_content_quality.py",
    "backup_file_script": "../audio-to-social/scripts/backup_file.py",
    "bump_episode_script": "../audio-to-social/scripts/bump_episode.py",
    "compress_images_script": "../audio-to-social/scripts/compress_images.py",
    "reconcile_media_script": "../audio-to-social/scripts/reconcile_media.py",
    "voice_ref_wav": "../audio-to-social/scripts/voice_ref.wav",
    "brand_config": "../audio-to-social/references/brand-config.md"
  }
}
